{
  "name": "creator-analyzer",
  "version": "0.3.1",
  "description": "本地运行的创作者作品采集与内容分析工具",
  "main": "scrape-creator-multi.js",
  "private": true,
  "scripts": {
    "start": "node scrape-creator-multi.js",
    "dy": "node scrape-dy-creator-cdp.js",
    "bili": "node scrape-bili-creator-cdp.js",
    "xhs": "node scrape-xhs-creator.js",
    "normalize": "node normalize-csv.js",
    "test": "node test-csv-normalizer.js && node test-platform-support.js",
    "dry-run": "node scrape-creator-multi.js bili demo-bili-user 5 --dry-run",
    "dry-run:xhs": "node scrape-xhs-creator.js demo-xhs-user 5 --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "playwright": "^1.61.0",
    "ws": "^8.18.0"
  }
}
